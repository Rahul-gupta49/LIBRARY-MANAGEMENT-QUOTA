<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container">
  <div class="page-header">
    <h1>👤 Add Student</h1>
    <a href="/teacher/students" class="btn btn-primary">← Back to Students</a>
  </div>

  <div class="card" style="max-width: 600px;">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/teacher/students/add">
      <div class="form-group">
        <label for="full_name">Full Name</label>
        <input type="text" id="full_name" name="full_name" required placeholder="Enter student's full name">
      </div>

      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required placeholder="Choose a username">
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Minimum 6 characters">
      </div>

      <button type="submit" class="btn btn-success btn-block">Add Student</button>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
