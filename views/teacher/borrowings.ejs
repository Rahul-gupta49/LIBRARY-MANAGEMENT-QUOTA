<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container">
  <div class="page-header">
    <h1>📋 All Borrowings</h1>
  </div>

  <div class="card">
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Student</th>
            <th>Book</th>
            <th>ISBN</th>
            <th>Borrow Date</th>
            <th>Due Date</th>
            <th>Return Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (borrowings.length === 0) { %>
            <tr><td colspan="7" class="text-center">No borrowings recorded.</td></tr>
          <% } %>
          <% borrowings.forEach(b => { %>
            <tr>
              <td><%= b.student_name %><br><small>@<%= b.student_username %></small></td>
              <td><strong><%= b.book_title %></strong><br><small><%= b.book_author %></small></td>
              <td><%= b.isbn %></td>
              <td><%= new Date(b.borrow_date).toLocaleDateString() %></td>
              <td><%= new Date(b.due_date).toLocaleDateString() %></td>
              <td><%= b.return_date ? new Date(b.return_date).toLocaleDateString() : '-' %></td>
              <td>
                <% if (b.status === 'returned') { %>
                  <span class="badge badge-returned">Returned</span>
                <% } else if (new Date(b.due_date) < new Date()) { %>
                  <span class="badge badge-overdue">Overdue</span>
                <% } else { %>
                  <span class="badge badge-borrowed">Borrowed</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
