<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container">
  <h1 style="color: #1a237e; margin-bottom: 1.5rem;">Welcome, <%= user.full_name %> 👋</h1>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-number"><%= stats.totalBooks %></div>
      <div class="stat-label">Total Books</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= stats.totalStudents %></div>
      <div class="stat-label">Registered Students</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= stats.activeBorrowings %></div>
      <div class="stat-label">Active Borrowings</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= stats.overdueBorrowings %></div>
      <div class="stat-label">Overdue Books</div>
    </div>
  </div>

  <div class="card">
    <h2>Quick Actions</h2>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem;">
      <a href="/teacher/books/add" class="btn btn-primary">➕ Add New Book</a>
      <a href="/teacher/books" class="btn btn-success">📖 Manage Books</a>
      <a href="/teacher/students/add" class="btn btn-warning">👤 Add Student</a>
      <a href="/teacher/borrowings" class="btn btn-danger">📋 View Borrowings</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
