<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container">
  <div class="page-header">
    <h1>📜 Borrowing History</h1>
  </div>

  <div class="card">
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Book</th>
            <th>Author</th>
            <th>Borrowed On</th>
            <th>Due Date</th>
            <th>Returned On</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (borrowings.length === 0) { %>
            <tr><td colspan="6" class="text-center">No borrowing history yet.</td></tr>
          <% } %>
          <% borrowings.forEach(b => { %>
            <tr>
              <td><strong><%= b.book_title %></strong></td>
              <td><%= b.book_author %></td>
              <td><%= new Date(b.borrow_date).toLocaleDateString() %></td>
              <td><%= new Date(b.due_date).toLocaleDateString() %></td>
              <td><%= b.return_date ? new Date(b.return_date).toLocaleDateString() : '-' %></td>
              <td>
                <% if (b.status === 'returned') { %>
                  <span class="badge badge-returned">Returned</span>
                <% } else if (new Date(b.due_date) < new Date()) { %>
                  <span class="badge badge-overdue">Overdue</span>
                <% } else { %>
                  <span class="badge badge-borrowed">Borrowed</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
