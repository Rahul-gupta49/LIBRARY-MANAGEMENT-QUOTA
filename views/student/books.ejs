<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container">
  <div class="page-header">
    <h1>📖 Browse Books</h1>
  </div>

  <form method="GET" action="/student/books" class="search-bar">
    <input type="text" name="search" placeholder="Search by title or author..." value="<%= search %>">
    <select name="category">
      <option value="">All Categories</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-primary">Search</button>
    <% if (search || category) { %>
      <a href="/student/books" class="btn btn-danger">Clear</a>
    <% } %>
  </form>

  <% if (books.length === 0) { %>
    <div class="card text-center">
      <p>No books found matching your search.</p>
    </div>
  <% } else { %>
    <div class="book-grid">
      <% books.forEach(book => { %>
        <div class="book-card">
          <h3><%= book.title %></h3>
          <p class="book-meta">✍️ <strong>Author:</strong> <%= book.author %></p>
          <p class="book-meta">📄 <strong>ISBN:</strong> <%= book.isbn %></p>
          <p class="book-meta">📂 <strong>Category:</strong> <%= book.category %></p>
          <p class="book-meta">
            📦 <strong>Available:</strong>
            <span class="badge <%= book.available_copies > 0 ? 'badge-available' : 'badge-unavailable' %>">
              <%= book.available_copies %> / <%= book.total_copies %>
            </span>
          </p>
          <div class="book-actions">
            <% if (book.available_copies > 0) { %>
              <form method="POST" action="/student/books/borrow/<%= book.id %>">
                <button type="submit" class="btn btn-success btn-sm">Borrow</button>
              </form>
            <% } else { %>
              <span class="btn btn-danger btn-sm" style="opacity: 0.6; cursor: not-allowed;">Unavailable</span>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
